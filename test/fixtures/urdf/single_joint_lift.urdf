<?xml version="1.0"?>
<!--
  single_joint_lift: a synthetic single-prismatic lift fixture for the L3
  joint-drive INTRINSIC tracking-precision experiment (Physics milestone
  "L3 control verification", issue #180 / sub-issues #181 tracking error /
  #182 steady-state / #183 repeatability). NOT the forklift application
  model -- a minimal, license-clean robot authored for this repo's test
  suite.

  Structure:
    base_link    a fixed-base box (fix_base=True at import -> anchored to
                 world)
    lift_link    a box with a known mass, joined to base_link by ONE
                 PRISMATIC joint along +Z (a vertical lift)

  Purpose (vs lift_payload.urdf, the #184 droop-under-load fixture): this
  fixture isolates the drive's OWN tracking precision -- there is NO
  external payload and NO contact. The single moving link is light (1 kg)
  so that, with a moderate stiffness + CRITICAL damping, the position
  drive tracks a commanded trajectory tightly and settles at rest with a
  tiny, deterministic steady-state error. The experiment commands a step
  and a smooth multi-point trajectory and records commanded vs measured
  DOF each step, measuring:
    (1) tracking error (max + RMS over the trajectory),
    (2) steady-state error at rest,
    (3) repeatability across runs/resets.

  Both links carry inertials so the importer keeps the prismatic joint.
  Geometry is primitive boxes -- no external mesh asset. The prismatic
  drive stores stiffness in N/m (a linear joint is NOT scaled by pi/180 --
  that scaling is angular-only).
-->
<robot name="single_joint_lift">

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
    </collision>
  </link>

  <link name="lift_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.15 0.15 0.15"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.15 0.15 0.15"/>
      </geometry>
    </collision>
  </link>

  <joint name="lift_joint" type="prismatic">
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="lift_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.0" upper="2.0" effort="1000.0" velocity="5.0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

</robot>
