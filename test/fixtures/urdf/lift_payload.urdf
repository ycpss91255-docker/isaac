<?xml version="1.0"?>
<!--
  lift_payload: a synthetic single-prismatic lift fixture for the L3 / L2.5
  drive-precision-under-load experiment (Physics milestone "L3 control
  verification", issue #184 / sub-issue #185). NOT the forklift application
  model -- a minimal, license-clean robot authored for this repo's test
  suite.

  Structure:
    base_link     a fixed-base box (fix_base=True at import -> anchored)
    payload_link  a box with a KNOWN mass, joined to base_link by a single
                  PRISMATIC joint along +Z (a vertical lift)

  The point of the experiment: drive the prismatic joint to a target height
  while gravity pulls the payload down. At steady state the position drive
  balances gravity, so the joint rests BELOW the commanded target by the
  droop  sag = m*g / stiffness  (a linear/prismatic drive stores stiffness in
  N/m, NOT scaled by pi/180 -- that scaling is angular-only). A high stiffness
  (L2.5) gives a tiny droop ("command ~ position"); a low stiffness (L3) gives
  a large, realistic droop. The contrast is the experiment.

  Mass is 10 kg so m*g ~ 98.1 N: at stiffness 5000 N/m the droop is ~2.0 cm
  (L2.5), at 200 N/m it is ~49 cm (L3) -- a 25x spread, visible and
  predictable. Both links carry inertials so the importer keeps the prismatic
  joint. Geometry is primitive boxes -- no external mesh asset.
-->
<robot name="lift_payload">

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
    </collision>
  </link>

  <link name="payload_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.2 0.2"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.2 0.2"/>
      </geometry>
    </collision>
  </link>

  <joint name="lift_joint" type="prismatic">
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="payload_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5" upper="1.5" effort="1000.0" velocity="5.0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

</robot>
