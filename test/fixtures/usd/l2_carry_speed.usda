#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
)

# TEST-ONLY FIXTURE -- the kinematic carry speed-limit experiment
# (#201 sub-issue, milestone "Physics: L2 true-kinematic + hybrid").
#
# A KINEMATIC mover (a thin platform) starts low with a DYNAMIC payload
# resting on top, then is RAMPED upward via dc.set_rigid_body_pose at a
# configurable per-tick displacement. dc.set_rigid_body_pose is a teleport
# (setGlobalPose) that BYPASSES the contact integrator (ADR-0008), so if the
# mover jumps too far in one tick it leaves the payload behind / tunnels past
# it. Sweeping the per-tick step measures the effective carry speed limit:
# slow ramps carry the payload (it rises with the mover), fast ramps drop it.
#
# Prims:
#   /World/PhysicsScene  -- gravity enabled (Z down, 9.81 m/s^2).
#   /World/Ground        -- static collider (catches the payload when it is
#                           left behind by a too-fast ramp).
#   /World/Mover         -- KINEMATIC rigid body (physics:kinematicEnabled=1);
#                           the carrier under test. Starts at z=0.5.
#   /World/Payload       -- DYNAMIC rigid body; rests on the mover top at
#                           z=0.70 (mover top 0.5 + half 0.05 = 0.55; payload
#                           half-height 0.15 -> centred at 0.70).

def Xform "World"
{
    def DistantLight "SunLight"
    {
        float inputs:intensity = 3000
        float3 xformOp:rotateXYZ = (-45, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    def PhysicsScene "PhysicsScene"
    {
        float physics:gravityMagnitude = 9.81
        vector3f physics:gravityDirection = (0, 0, -1)
    }

    # Static ground collider at z = 0 (a thin slab). Not a rigid body, so it
    # never moves; under a too-fast ramp the dropped payload lands here.
    def Cube "Ground" (
        prepend apiSchemas = ["PhysicsCollisionAPI"]
    )
    {
        double size = 1
        float3 xformOp:scale = (20, 20, 0.02)
        double3 xformOp:translate = (0, 0, -0.01)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.45, 0.45, 0.45)]
    }

    # KINEMATIC mover -- the carrier under test. Ramped upward via
    # dc.set_rigid_body_pose at a configurable per-tick step. Starts at z=0.5.
    def Cube "Mover" (
        prepend apiSchemas = [
            "PhysicsRigidBodyAPI",
            "PhysicsCollisionAPI",
            "PhysicsMassAPI",
            "PhysxRigidBodyAPI"
        ]
    )
    {
        double size = 1
        float3 xformOp:scale = (1.0, 1.0, 0.1)
        double3 xformOp:translate = (0, 0, 0.5)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        float physics:mass = 50
        bool physics:kinematicEnabled = 1
        color3f[] primvars:displayColor = [(0.1, 0.4, 0.85)]
    }

    # DYNAMIC payload (10 kg) resting on the mover top. Gravity pulls it down
    # onto the mover; a slow ramp carries it up, a fast ramp leaves it behind.
    def Cube "Payload" (
        prepend apiSchemas = [
            "PhysicsRigidBodyAPI",
            "PhysicsCollisionAPI",
            "PhysicsMassAPI",
            "PhysxRigidBodyAPI"
        ]
    )
    {
        double size = 1
        float3 xformOp:scale = (0.3, 0.3, 0.3)
        double3 xformOp:translate = (0, 0, 0.70)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        float physics:mass = 10
        color3f[] primvars:displayColor = [(0.85, 0.55, 0.1)]
    }
}
