# managed by template (do not remove)
.env
.env.bak
compose.yaml
setup.conf.bak
setup.conf.local
coverage/
.Dockerfile.generated

.docker.xauth

# Docker bind-mount auto-mkdir artifacts (root-owned ghost dirs)
isaac_ws/

# Per-host deployment config (use config/host.yaml.example as template)
config/host.yaml

# Per-instance overlays (base #465) — machine-specific (ports / cache
# paths). The committed example.{env,yaml} template is the exception.
/config/instances/*
!/config/instances/example.env
!/config/instances/example.yaml
# Per-instance cache trees — created by the pre-run hook.
/instance/

runtime.env

.env.generated

# Python artifacts (isaac_devkit framework + pytest, #130)
__pycache__/
*.py[cod]
.coverage
.coverage.*
.pytest_cache/
htmlcov/
# colcon build artifacts (example/ros2 ament packages, #133)
build/
install/
log/

# GPU integration JUnit report (assert_pytest_baseline.sh --gpu, M2 gate, #132)
test/.gpu-pytest-report.xml
