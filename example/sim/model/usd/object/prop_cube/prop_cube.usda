#usda 1.0
(
    metersPerUnit = 1
    upAxis = "Z"
)

# A primitive cube prop for the camera_bot example (object.yaml). Geometry
# only -- the physics level (mobility: dynamic) is declared in the scene,
# not baked here (ADR-0017 section 4: adjustments go back to the source
# model, scenes stay ephemeral).
def Xform "prop_cube"
{
    def Cube "geometry"
    {
        double size = 0.5
        color3f[] primvars:displayColor = [(0.8, 0.3, 0.2)]
    }
}
