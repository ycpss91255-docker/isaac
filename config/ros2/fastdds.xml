<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Fast DDS profile for cross-container DDS on the same host.
  Source: NVIDIA Isaac Sim 5.1 official ROS 2 install guide
    https://docs.isaacsim.omniverse.nvidia.com/5.1.0/installation/install_ros.html

  Disables built-in transports (which include SHM that may misbehave
  across containers even with --ipc=host) and forces UDPv4 only, so
  participants on the host network reliably discover each other.

  Pointed to by FASTRTPS_DEFAULT_PROFILES_FILE in setup.conf
  [environment]; baked into the image at /isaac-sim/fastdds.xml.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <transport_descriptors>
        <transport_descriptor>
            <transport_id>UdpTransport</transport_id>
            <type>UDPv4</type>
        </transport_descriptor>
    </transport_descriptors>
    <participant profile_name="udp_transport_profile" is_default_profile="true">
        <rtps>
            <userTransports>
                <transport_id>UdpTransport</transport_id>
            </userTransports>
            <useBuiltinTransports>false</useBuiltinTransports>
        </rtps>
    </participant>
</profiles>
