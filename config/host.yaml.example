# Per-host deployment config. Copy to config/host.yaml (gitignored) and fill values.
# Read inside the container by /usr/local/bin/runheadless-host-config.sh (Isaac)
# and by the omniverse_web_viewer entrypoint when mounted as /etc/host.yaml.
#
# The launcher (Makefile.local / run_instance.sh) copies / mounts this file
# into the container when it exists. Missing file = no mount, defaults apply.

network:
  # Host LAN IP for WebRTC ICE candidates. 127.0.0.1 = localhost-only browser
  # access. Change to this machine's LAN IP (e.g. "192.168.50.1") for remote
  # browser access from another machine on the same network.
  public_ip: "127.0.0.1"
