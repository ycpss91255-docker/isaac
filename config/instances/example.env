# Per-instance configuration template (base #465).
#
# Copy to config/instances/<name>.env (and <name>.yaml) and edit, then:
#   ./run.sh -t stream -d --instance <name>
#
# `run.sh --instance <name>` loads this file via --env-file and deep-merges
# the sibling <name>.yaml as a compose overlay. The pre/post run hooks also
# read it (cache dir tree + web-viewer ports).
#
# IMPORTANT: cache dirs MUST NOT be shared between instances -- Isaac's
# Vulkan / Kit / OV caches use file locks that crash on concurrent or
# shared access. Ports must be unique per instance (TCP/UDP bind conflict).

# -- Ports --------------------------------------------------------------
# Two name sets are intentional: Kit reads ISAAC_* (compose env), while the
# web-viewer container is launched by the post-run hook via
# `docker --env-file <this file>` -- and --env-file is LITERAL (no ${VAR}
# interpolation), so the viewer keys (SIGNALING_PORT / MEDIA_PORT /
# SERVE_PORT) must be spelled out here with the same numeric values.
#
# Default-instance values. For a second concurrent instance bump BOTH name
# sets by their offset (signal/media +100, api/viewer +1), e.g.
# 49200 / 48098 / 8012 / 5174.
ISAAC_SIGNAL_PORT=49100
ISAAC_MEDIA_PORT=47998
ISAAC_API_PORT=8011
VIEWER_PORT=5173

# Viewer-facing key names (consumed via --env-file; keep in sync with the
# ISAAC_* values above).
SIGNALING_PORT=49100
MEDIA_PORT=47998
SERVE_PORT=5173

# -- Cache --------------------------------------------------------------
# Cache root for this instance. The leading './' is REQUIRED: the overlay
# <name>.yaml uses this value as a docker compose bind-mount source, and
# compose reads a BARE relative path containing slashes (e.g.
# "instance/example") as an invalid NAMED VOLUME -- it will not bind-mount
# the directory. The './' prefix forces a relative-path bind mount that
# resolves against the repo root for BOTH compose and the pre-run hook
# (which mkdirs the kit/ov/nvidia subtree). An absolute path also works
# (e.g. /mnt/ssd/isaac-cache/<name>) but is not portable across machines.
INSTANCE_CACHE_DIR=./instance/example
